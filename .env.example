# === LLM Providers ===
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === External APIs ===
# SEC EDGAR requires a User-Agent header (Company/App Name and Email)
SEC_USER_AGENT="QuantumEdgeResearch admin@quantumedge.com"

# Search APIs (Choose one you registered for)
TAVILY_API_KEY=your_tavily_api_key_here
SERPAPI_KEY=your_serpapi_key_here

# Financial APIs
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here
FMP_API_KEY=your_fmp_api_key_here
NEWSAPI_KEY=your_newsapi_key_here

# === LangSmith Observability ===
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT="Compliance_Monitoring_System_Project1B"

# === Agent Settings ===
MAX_ITERATIONS=15
